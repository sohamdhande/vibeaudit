# VibeAudit Environment Configuration
# This is the unified .env.example for the entire monorepo.
# Create a .env file in the `scanner/` and `frontend/` directories using these variables.

# ==========================================
# SCANNER BACKEND (scanner/.env)
# ==========================================

# --- Required ---
# AI API Key for patch generation. (e.g. GROQ_API_KEY)
GROQ_API_KEY=your_api_key_here

# Security key required to authenticate scan requests. Minimum 32 characters.
VIBEAUDIT_API_KEY=your_secret_api_key_must_be_32_chars_or_more

# --- Optional: GitHub Integration ---
# Required only for automated PR generation. Needs repo read/write permissions.
GITHUB_TOKEN=ghp_your_token_here

# (You must enter the target repository owner and name directly in the VibeAudit UI)
GITHUB_BASE_BRANCH=main

# --- Server Configuration ---
# Port for the scanner backend (default 4000)
PORT=4000


# ==========================================
# FRONTEND (frontend/.env)
# ==========================================

# --- Required ---
# Required to authenticate scan requests with the backend via proxy.
# MUST MATCH VIBEAUDIT_API_KEY in the scanner. Server-only, never prefix with NEXT_PUBLIC_.
SCANNER_API_KEY=your_secret_api_key_must_be_32_chars_or_more

# URL of the VibeAudit scanner backend (default: http://localhost:4000)
NEXT_PUBLIC_SCANNER_URL=http://localhost:4000

# Origin of the scanner backend (used for CSP connect-src). No trailing slash.
NEXT_PUBLIC_SCANNER_ORIGIN=http://localhost:4000
